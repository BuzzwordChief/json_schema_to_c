{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "root",
    "oneOf": [
        {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "value"],
            "properties": {
                "type": { "const": "alpha" },
                "value": { "type": "integer", "default": 0 }
            }
        },
        {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "label"],
            "properties": {
                "type": { "const": "beta" },
                "label": { "type": "string", "maxLength": 8, "default": "ok" }
            }
        }
    ]
}