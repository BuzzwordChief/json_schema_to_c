{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "root",
    "description": "Some demo structure for demoing.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "vegetable"
    ],
    "properties": {
        "vegetable": {
            "type": "array",
            "maxItems": 2,
            "items": [
                {
                    "type": "string",
                    "maxLength": 8
                },
                {
                    "type": "integer"
                }
            ]
        }
    }
}